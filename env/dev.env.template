# Copy to env/dev.env (gitignored) and adjust.
LZ=m3
ENV=dev
NODE_ENV=production
NEXT_PUBLIC_APP_ENV=dev

# Base URL of the druthers-api backend (server-side only; the BFF calls it).
# On the shared homelab network use the API container name, e.g.
# http://gs_druthers_api_prod:8000
API_BASE_URL=http://m3_druthers_api_dev:8000

# Google Sign-In (non-prod OAuth client, localhost:3000 authorized — see
# google-oauth-clients-aleonard memory). Must match GOOGLE_CLIENT_ID in
# druthers-api/env/dev.env.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
